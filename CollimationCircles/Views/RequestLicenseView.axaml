<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="550"
		d:DesignHeight="170"
		x:Class="CollimationCircles.Views.RequestLicenseView"
		xmlns:controls="clr-namespace:CollimationCircles.Controls"
		Title="{Binding Title}"
		xmlns:vm="using:CollimationCircles.ViewModels"
		x:DataType="vm:RequestLicenseViewModel"
		Width="550" Height="170"
		Icon="/Resources/Images/icon_256px.ico"
		WindowStartupLocation="CenterScreen">
	<StackPanel
	Margin="20"
	Spacing="10"
	Orientation="Vertical">
		<TextBlock
		Text="{DynamicResource Text.LicenseData}"/>
		<SelectableTextBlock
		TextWrapping="Wrap"
		SelectionStart="0"
		SelectionEnd="{ReflectionBinding LicenseRequestText.Length}"
		Text="{ReflectionBinding LicenseRequestText}"/>		
		<TextBlock
		TextWrapping="Wrap"
		FontWeight="Bold"
		Foreground="IndianRed"
		Text="{DynamicResource Text.BuyLicenseInstructions}"/>
		<StackPanel Orientation="Horizontal" Spacing="{DynamicResource ControlSpacing}">
			<Button
			Content="{DynamicResource Text.BuyLicense}"
			Command="{ReflectionBinding BuyLicense}"/>			
		</StackPanel>
	</StackPanel>
</Window>
