# Attempt to rerun libusb_set_interface_alt_setting if fails
#
# See https://github.com/libuvc/libuvc/pull/293
#
# This issues fixes error UVC_ERROR_OTHER = -99 when trying to start streaming with SVBony sv105
# The fix is to run once again set interface (ioctl) if it fails and that solves the proble,

From 212b85dbadf9f13a35c7b187fa4f97b93e18cffa Mon Sep 17 00:00:00 2001
From: Artyom Beilis <artyomtnk@yahoo.com>
Date: Fri, 2 May 2025 08:03:10 +0300
Subject: [PATCH] Attempt to rerun libusb_set_interface_alt_setting if fails,
 fixes issues with SVBony cameras

---
 src/stream.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/src/stream.c b/src/stream.c
index 89dac69..49e0fd7 100644
--- a/src/stream.c
+++ b/src/stream.c
@@ -1141,6 +1141,8 @@ uvc_error_t uvc_stream_start(
     size_t endpoint_bytes_per_packet = 0;
     /* Index of the altsetting */
     int alt_idx, ep_idx;
+    /* Attempts to change settings */
+    int attempts;
     
     config_bytes_per_packet = strmh->cur_ctrl.dwMaxPayloadTransferSize;
 
@@ -1197,9 +1199,13 @@ uvc_error_t uvc_stream_start(
     }
 
     /* Select the altsetting */
-    ret = libusb_set_interface_alt_setting(strmh->devh->usb_devh,
+    attempts = 0;
+    do {
+        attempts ++;
+        ret = libusb_set_interface_alt_setting(strmh->devh->usb_devh,
                                            altsetting->bInterfaceNumber,
                                            altsetting->bAlternateSetting);
+    } while(ret != UVC_SUCCESS && attempts < 3);
     if (ret != UVC_SUCCESS) {
       UVC_DEBUG("libusb_set_interface_alt_setting failed");
       goto fail;
