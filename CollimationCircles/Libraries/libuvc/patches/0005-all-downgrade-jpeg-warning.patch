# All platforms — applied on macOS, Linux, and Windows
#
# We intentionally build libuvc without JPEG support (-DCMAKE_DISABLE_FIND_PACKAGE_JpegPkg=ON)
# because the camera sends raw MJPEG bytes that are decoded in C# by FrameRenderer.
# Enabling JPEG would add a dependency on libjpeg/libjpeg-turbo that would need
# to be bundled separately.
#
# The original code emits a CMake WARNING which is misleading — it looks like an
# error. This patch downgrades it to STATUS (informational message).

diff --git a/CMakeLists.txt b/CMakeLists.txt
index fbaffc9..076e544 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -48,7 +48,7 @@ if(JPEG_FOUND)
   set(LIBUVC_HAS_JPEG TRUE)
   list(APPEND SOURCES src/frame-mjpeg.c)
 else()
-  message(WARNING "JPEG not found. libuvc will not support JPEG decoding.")
+  message(STATUS "JPEG not found (intentionally disabled). libuvc will not support JPEG decoding.")
 endif()
 
 if(UNIX AND NOT APPLE)
