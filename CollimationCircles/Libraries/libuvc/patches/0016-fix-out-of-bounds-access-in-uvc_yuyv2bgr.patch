# fix out-of-bounds access in uvc_yuyv2bgr
#
# See https://github.com/libuvc/libuvc/pull/211
#
# with my camera, using the example program, i see a very high rate of crashes in uvc_yuyv2bgr().
# i tracked this to reading beyond the end of the input buffer.
# the IYUYV2BGR* macros make this hard to debug, but adding a read of the to-be read source data before the macro call made it obvious

From eb97bc2963479f1e519be6a3d308fc0422565b02 Mon Sep 17 00:00:00 2001
From: r00t <r00t@constancy.org>
Date: Wed, 9 Mar 2022 06:11:58 +0100
Subject: [PATCH] fix out-of-bounds access in uvc_yuyv2bgr() and uvc_yuyv2bgr()

---
 src/frame.c | 16 ++++++++++++----
 1 file changed, 12 insertions(+), 4 deletions(-)

diff --git a/src/frame.c b/src/frame.c
index 1d1dd417..2641e4db 100644
--- a/src/frame.c
+++ b/src/frame.c
@@ -175,6 +175,9 @@ uvc_error_t uvc_yuyv2rgb(uvc_frame_t *in, uvc_frame_t *out) {
   if (in->frame_format != UVC_FRAME_FORMAT_YUYV)
     return UVC_ERROR_INVALID_PARAM;
 
+  if (in->data_bytes < in->width * in->height * 2)
+    return UVC_ERROR_INVALID_PARAM;
+
   if (uvc_ensure_frame_size(out, in->width * in->height * 3) < 0)
     return UVC_ERROR_NO_MEM;
 
@@ -189,9 +192,10 @@ uvc_error_t uvc_yuyv2rgb(uvc_frame_t *in, uvc_frame_t *out) {
 
   uint8_t *pyuv = in->data;
   uint8_t *prgb = out->data;
-  uint8_t *prgb_end = prgb + out->data_bytes;
+  uint8_t *prgb_end = prgb + out->data_bytes - 3 * 8 + 1;
+  uint8_t *pyuv_end = pyuv + in->data_bytes - 2 * 8 + 1;
 
-  while (prgb < prgb_end) {
+  while (prgb < prgb_end && pyuv < pyuv_end) {
     IYUYV2RGB_8(pyuv, prgb);
 
     prgb += 3 * 8;
@@ -226,6 +230,9 @@ uvc_error_t uvc_yuyv2bgr(uvc_frame_t *in, uvc_frame_t *out) {
   if (in->frame_format != UVC_FRAME_FORMAT_YUYV)
     return UVC_ERROR_INVALID_PARAM;
 
+  if (in->data_bytes < in->width * in->height * 2)
+    return UVC_ERROR_INVALID_PARAM;
+
   if (uvc_ensure_frame_size(out, in->width * in->height * 3) < 0)
     return UVC_ERROR_NO_MEM;
 
@@ -240,9 +247,10 @@ uvc_error_t uvc_yuyv2bgr(uvc_frame_t *in, uvc_frame_t *out) {
 
   uint8_t *pyuv = in->data;
   uint8_t *pbgr = out->data;
-  uint8_t *pbgr_end = pbgr + out->data_bytes;
+  uint8_t *pyuv_end = pyuv + in->data_bytes;
+  uint8_t *pbgr_end = pbgr + out->data_bytes;
 
-  while (pbgr < pbgr_end) {
+  while (pyuv < pyuv_end && pbgr < pbgr_end) {
     IYUYV2BGR_8(pyuv, pbgr);
 
     pbgr += 3 * 8;
