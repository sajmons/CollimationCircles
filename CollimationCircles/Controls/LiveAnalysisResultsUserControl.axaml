<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
			 x:Class="CollimationCircles.Controls.LiveAnalysisResultsUserControl"
			 xmlns:vm="using:CollimationCircles.ViewModels"
			 x:DataType="vm:CollimationAnalysisViewModel">

	<StackPanel Orientation="Vertical" Spacing="{DynamicResource ControlSpacing}">
		<Grid 
			ColumnSpacing="{DynamicResource ControlSpacing}"
			RowSpacing="{DynamicResource ControlSpacing}"
			ColumnDefinitions="Auto,*"
			RowDefinitions="Auto,Auto">
			
			<TextBlock				
				Text="Defocused star analysis"
				VerticalAlignment="Center"/>
			<ToggleSwitch 
				Grid.Column="1"
				IsChecked="{Binding IsLiveAnalysisActive}"
				IsEnabled="{Binding IsStreaming}"
				ToolTip.Tip="Toggle Real-time Advanced Analysis Result Overlay">				
			</ToggleSwitch>			

			<TextBlock 
				Grid.Row="1"				
				Text="Optical tube analysis"
				VerticalAlignment="Center"/>
			<ToggleSwitch
				Grid.Row="1"
				Grid.Column="1"
				IsChecked="{Binding IsLiveRmseActive}"
				IsEnabled="{Binding IsStreaming}"
				HorizontalAlignment="Stretch"
				ToolTip.Tip="Toggle Real-time Mechanical RMSE Analysis">				
			</ToggleSwitch>			
		</Grid>

		<TextBlock
			IsVisible="{Binding !IsStreaming}"
			Text="To start live analysis, you must first start camera stream"
			VerticalAlignment="Center"
			TextWrapping="Wrap"/>

		<Border IsVisible="{Binding IsAnyLiveAnalysisActive}"
				Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
				BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
				BorderThickness="2"
				Padding="12"
				CornerRadius="8"
				Margin="0,8,0,8">
			<StackPanel Spacing="6">
				<TextBlock 
					Text="{Binding LiveResultText}"
					FontFamily="Consolas,Courier New"
					FontSize="12"
					TextWrapping="Wrap"
					IsVisible="{Binding LiveResultText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

				<ItemsControl ItemsSource="{Binding ScrewInstructions}" Margin="0,4">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Background="#1AFFFFFF" CornerRadius="4" Padding="8,4" Margin="0,2">
								<Grid ColumnDefinitions="20,Auto,*">
									<Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding Brush}" HorizontalAlignment="Left"/>
									<TextBlock Grid.Column="1" Text="{Binding Id, StringFormat='Screw {0}: '}" Foreground="LightGray" VerticalAlignment="Center" FontSize="11"/>
									<TextBlock Grid.Column="2" Text="{Binding DisplayText}" Foreground="Lime" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</Border>
	</StackPanel>
</UserControl>
