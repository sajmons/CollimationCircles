<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
             x:Class="CollimationCircles.Controls.AIUserControl"
             xmlns:vm="using:CollimationCircles.ViewModels"
             x:DataType="vm:AIViewModel">

  <StackPanel
    Orientation="Vertical"
    Spacing="{DynamicResource ControlSpacing}">

    <Grid
      ColumnDefinitions="*,Auto">
      <TextBox
          VerticalAlignment="Bottom"
          Watermark="{DynamicResource Text.EnterOpenApiKey}"
          Text="{ReflectionBinding ApiKey}" />
      <Button
          IsEnabled="{ReflectionBinding IsValidOpenApiKey}"
          Grid.Column="1"
          Theme="{DynamicResource ToolbarButton}"
          Command="{ReflectionBinding SetOpenApiKeyCommand}">
        <PathIcon
          Width="{DynamicResource PathIconWidth}"
          Height="{DynamicResource PathIconHeight}"
          Foreground="{DynamicResource Color2}"
          Data="{StaticResource IconData.ImageAnalysis}" />
      </Button>
    </Grid>

    <Button
        IsEnabled="{ReflectionBinding IsValidOpenApiKey}"
        Command="{ReflectionBinding SendToAICommand}">
      Analyze with AI
    </Button>

  </StackPanel>

</UserControl>
