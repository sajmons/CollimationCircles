<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CollimationCircles.ViewModels"
             xmlns:controls="clr-namespace:CollimationCircles.Controls"
             mc:Ignorable="d"
             d:DesignWidth="600"
             d:DesignHeight="280"
             x:Class="CollimationCircles.Controls.AboutTabUserControl"
             x:DataType="vm:AboutViewModel">
  <Border
        Background="{DynamicResource ExpanderContentBackground}"
        BorderThickness="{DynamicResource ExpanderHeaderBorderThickness}"
        BorderBrush="{DynamicResource ExpanderContentBorderBrush}"
        CornerRadius="{DynamicResource ControlCornerRadius}"
        Padding="{DynamicResource ExpanderContentPadding}">

    <StackPanel Spacing="8" Margin="8">

      <TextBlock
        TextWrapping="WrapWithOverflow"
        VerticalAlignment="Center"
        Text="{DynamicResource Text.AppDescription}">
      </TextBlock>

      <TextBlock
        HorizontalAlignment="Stretch"
        TextWrapping="WrapWithOverflow"
        VerticalAlignment="Center"
        Text="{DynamicResource Text.PatreonDesc}" />

      <StackPanel>
        <WrapPanel IsVisible="{Binding ValidLicense}">
          <TextBlock
            Margin="0 0 8 0"
            Text="{DynamicResource Text.License}"/>
          <TextBlock
            TextWrapping="WrapWithOverflow"
            Text="{ReflectionBinding License}"/>
        </WrapPanel>

        <StackPanel
          Orientation="Vertical"
          Spacing="{DynamicResource ControlSpacing}">

          <StackPanel
            Orientation="Horizontal"
            Spacing="{DynamicResource ControlSpacing}">

            <Button
              Width="110"
              HorizontalContentAlignment="Center"
              Command="{Binding PayPalDonateCommand}"
              Content="{DynamicResource Text.PayPalDonate}"/>

            <Button
              Width="110"
              HorizontalContentAlignment="Center"
              Command="{Binding OpenPatreonWebSiteCommand}"
              ToolTip.Tip="{DynamicResource Text.PatreonWebSite}"
              Content="{DynamicResource Text.Patreon}"/>

          </StackPanel>

          <StackPanel
            Orientation="Horizontal"
            Spacing="{DynamicResource ControlSpacing}">

            <Button
              Theme="{DynamicResource ToolbarButton}"
              Command="{Binding OpenContactWebPageCommand}"
              ToolTip.Tip="{DynamicResource Text.OpenWebSiteContactForm}">
              <PathIcon
                Width="{DynamicResource PathIconWidth}"
                Height="{DynamicResource PathIconHeight}"
                Foreground="{DynamicResource Color2}"
                Data="{StaticResource IconData.Email}" />
            </Button>

            <Button
              Theme="{DynamicResource ToolbarButton}"
              Command="{Binding OpenGitHubPageCommand}"
              ToolTip.Tip="{DynamicResource Text.GitHubWebSite}">
              <PathIcon
                Width="{DynamicResource PathIconWidth}"
                Height="{DynamicResource PathIconHeight}"
                Foreground="{DynamicResource Color2}"
                Data="{StaticResource IconData.GitHub}" />
            </Button>

            <Button
              Theme="{DynamicResource ToolbarButton}"
              Command="{Binding OpenTwitterCommand}"
              ToolTip.Tip="{DynamicResource Text.TwitterWebSite}">
              <PathIcon
                Width="{DynamicResource PathIconWidth}"
                Height="{DynamicResource PathIconHeight}"
                Foreground="{DynamicResource Color2}"
                Data="{StaticResource IconData.Twetter}" />
            </Button>

            <Button
              Theme="{DynamicResource ToolbarButton}"
              Command="{Binding OpenYouTubeChannelCommand}"
              ToolTip.Tip="{DynamicResource Text.YouTubeChannel}">
              <PathIcon
                Width="{DynamicResource PathIconWidth}"
                Height="{DynamicResource PathIconHeight}"
                Foreground="{DynamicResource Color2}"
                Data="{StaticResource IconData.YouTube}" />
            </Button>

            <Button
              Theme="{DynamicResource ToolbarButton}"
              Command="{Binding GitHubIssueCommand}"
              ToolTip.Tip="{DynamicResource Text.OpenGitHubIssue}">
              <PathIcon
                Width="{DynamicResource PathIconWidth}"
                Height="{DynamicResource PathIconHeight}"
                Foreground="{DynamicResource Color2}"
                Data="{StaticResource IconData.Bug}" />
            </Button>
          </StackPanel>

        </StackPanel>

      </StackPanel>

    </StackPanel>
  </Border>

</UserControl>
