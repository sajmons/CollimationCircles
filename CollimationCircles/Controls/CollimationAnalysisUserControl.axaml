<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
             x:Class="CollimationCircles.Controls.CollimationAnalysisUserControl"
             xmlns:vm="using:CollimationCircles.ViewModels"
             x:DataType="vm:CollimationAnalysisViewModel">

  <StackPanel
    Orientation="Vertical"
    Spacing="{DynamicResource ControlSpacing}">

    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource ControlSpacing}">
      <ToggleButton
          Theme="{DynamicResource ToolbarToggleButton}"
          IsChecked="{Binding IsLiveAnalysisActive}"
          HorizontalAlignment="Left"
          IsEnabled="{Binding IsPlaying}"
          ToolTip.Tip="Toggle Real-time Advanced Analysis Result Overlay">
        <PathIcon
          Width="{DynamicResource PathIconWidth}"
          Height="{DynamicResource PathIconHeight}"
          Foreground="{DynamicResource Color2}"
          Data="{StaticResource IconData.Analyze}" />
      </ToggleButton>

      <ToggleButton
          Theme="{DynamicResource ToolbarToggleButton}"
          IsChecked="{Binding IsLiveRmseActive}"
          HorizontalAlignment="Left"
          IsEnabled="{Binding IsPlaying}"
          ToolTip.Tip="Toggle Real-time Mechanical RMSE Analysis">
        <PathIcon
          Width="{DynamicResource PathIconWidth}"
          Height="{DynamicResource PathIconHeight}"
          Foreground="{DynamicResource Color2}"
          Data="{StaticResource IconData.Shapes}" />
      </ToggleButton>
    </StackPanel>

    <Border IsVisible="{Binding IsAnyLiveAnalysisActive}"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
            BorderThickness="2"
            Padding="12"
            CornerRadius="8"
            Margin="0,8,0,8">
      <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Ellipse Width="8" Height="8" Fill="Red">
            <Ellipse.Styles>
              <Style Selector="Ellipse">
                <Style.Animations>
                  <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                      <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.5">
                      <Setter Property="Opacity" Value="0.2"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1">
                      <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                  </Animation>
                </Style.Animations>
              </Style>
            </Ellipse.Styles>
          </Ellipse>
          <TextBlock Text="LIVE ANALYSIS" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" LetterSpacing="1"/>
        </StackPanel>
        
        <TextBlock Text="{Binding LiveResultText}" 
                   FontFamily="Consolas,Courier New"
                   FontSize="12"
                   TextWrapping="Wrap"
                   IsVisible="{Binding LiveResultText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        
        <Image Source="{Binding AnalysisPreview}" 
               MaxWidth="250" 
               Margin="0,4,0,0"
               IsVisible="{Binding AnalysisPreview, Converter={x:Static ObjectConverters.IsNotNull}}"/>

        <TextBlock Text="Waiting for stream data..." 
                   FontStyle="Italic"
                   FontSize="12"
                   Opacity="0.6"
                   IsVisible="{Binding LiveResultText, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
      </StackPanel>
    </Border>

  </StackPanel>

</UserControl>
